# Backend Environment Configuration - Production Template
# Note: DO NOT commit sensitive values to repository
# Set these variables in Render Dashboard

# Database URL (automatically provided by Render PostgreSQL add-on)
# DATABASE_URL will be set by Render

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Server Port
PORT=5000

# Environment
NODE_ENV=production
