DATABASE_URL="postgresql://username:password@localhost:5432/village_khata_manager"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"
PORT=5000

# Email Configuration (Password Reset Feature)
# Choose one email service below

# Gmail (Recommended for Development)
EMAIL_USER="your-email@gmail.com"
EMAIL_PASSWORD="your-16-character-app-password-from-google"

# Mailtrap (Best for Testing - Uncomment to use)
# EMAIL_SERVICE="smtp.mailtrap.io"
# EMAIL_PORT=2525
# EMAIL_USER="your_mailtrap_username"
# EMAIL_PASSWORD="your_mailtrap_password"

# Frontend URL (For Email Links)
FRONTEND_URL="http://localhost:5173"
