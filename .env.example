# Environment Variables Template
# Copy this file to .env and fill in actual values
# NEVER commit .env file to Git!

# Backend Environment Variables
# =============================

# Database Connection
# On Render: This is automatically set by the PostgreSQL add-on
# Locally: Use SQLite path or PostgreSQL connection string
DATABASE_URL="file:./prisma/dev.db"

# JWT Configuration
# Generate using: generate-jwt-secret.bat (Windows) or generate-jwt-secret.sh (Linux/Mac)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Server Configuration
PORT=5000
NODE_ENV="development"

# Frontend Environment Variables
# =============================

# API Base URL
# Development: http://localhost:5000/api (proxied through Vite)
# Production: https://your-backend-url.onrender.com/api
VITE_API_URL="http://localhost:5000/api"

# =============================
# Setup Instructions
# =============================
#
# LOCAL DEVELOPMENT:
# 1. Copy this file to .env in the backend directory
# 2. Copy this file to .env in the frontend directory
# 3. Update values as needed
# 4. Run: npm run dev
#
# PRODUCTION (RENDER):
# 1. DO NOT commit .env to Git
# 2. Set variables in Render Dashboard:
#    - Backend Service: Environment tab
#    - Frontend Service: Environment tab
# 3. Render will handle DATABASE_URL automatically
# 4. You only need to set:
#    - JWT_SECRET (backend)
#    - VITE_API_URL (frontend)
#
# SECURITY:
# - Never commit .env to Git (.gitignore will prevent this)
# - Never share JWT_SECRET publicly
# - Rotate secrets regularly in production
# - Use strong random values for secrets
#
